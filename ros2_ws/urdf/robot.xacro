<?xml version="1.0"?>
<!-- 差速驱动机器人 XACRO 模型：底盘 + 双驱动轮 + 随动轮 + 激光雷达 -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="diff_drive_robot">

  <!-- ==================== 尺寸参数（改这里即可联动所有部件） ==================== -->
  <xacro:property name="base_length" value="0.5"/>  <!-- 底盘长 -->
  <xacro:property name="base_width"  value="0.3"/>  <!-- 底盘宽 -->
  <xacro:property name="base_height" value="0.25"/> <!-- 底盘高 -->

  <xacro:property name="wheel_radius"   value="0.075"/> <!-- 驱动轮半径 -->
  <xacro:property name="wheel_width"    value="0.05"/>  <!-- 驱动轮宽度 -->
  <xacro:property name="wheel_separation" value="0.32"/> <!-- 左右轮间距（轮距） -->

  <xacro:property name="caster_radius" value="0.05"/> <!-- 随动轮半径 -->
  <xacro:property name="caster_width"  value="0.05"/> <!-- 随动轮宽度 -->

  <xacro:property name="laser_height" value="0.05"/> <!-- 激光雷达高度 -->
  <xacro:property name="laser_radius" value="0.03"/> <!-- 激光雷达半径 -->

  <!-- 质量参数（总重约2kg，合理分配） -->
  <xacro:property name="base_mass"   value="1.2"/>  <!-- 底盘质量 -->
  <xacro:property name="wheel_mass"  value="0.15"/> <!-- 单个驱动轮质量 -->
  <xacro:property name="caster_mass" value="0.1"/>  <!-- 随动轮质量 -->
  <xacro:property name="laser_mass"  value="0.05"/> <!-- 激光雷达质量 -->

  <!-- ==================== 惯性计算宏（Gazebo 仿真必需） ==================== -->
  <!-- 长方体惯性张量 -->
  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${mass*(x*x+z*z)/12}" iyz="0"
               izz="${mass*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <!-- 圆柱体惯性张量 -->
  <xacro:macro name="cylinder_inertia" params="mass radius height">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(3*radius*radius+height*height)/12}" ixy="0" ixz="0"
               iyy="${mass*(3*radius*radius+height*height)/12}" iyz="0"
               izz="${mass*radius*radius/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== 底盘 ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- ==================== 左驱动轮 ==================== -->
  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <xacro:cylinder_inertia mass="${wheel_mass}" radius="${wheel_radius}" height="${wheel_width}"/>
  </link>

  <joint name="base_to_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 ${wheel_separation/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ==================== 右驱动轮 ==================== -->
  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <xacro:cylinder_inertia mass="${wheel_mass}" radius="${wheel_radius}" height="${wheel_width}"/>
  </link>

  <joint name="base_to_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -${wheel_separation/2} ${wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ==================== 后方随动轮（固定，仅起支撑作用） ==================== -->
  <link name="caster_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${caster_radius}" length="${caster_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <material name="light_grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${caster_radius}" length="${caster_width}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
    </collision>
    <xacro:cylinder_inertia mass="${caster_mass}" radius="${caster_radius}" height="${caster_width}"/>
  </link>

  <joint name="base_to_caster" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_link"/>
    <origin xyz="-${base_length/2 - caster_radius} 0 ${caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== 激光雷达（安装在底盘顶部前方） ==================== -->
  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_height}"/>
      </geometry>
      <origin xyz="0 0 ${laser_height/2}" rpy="0 0 0"/>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_height}"/>
      </geometry>
      <origin xyz="0 0 ${laser_height/2}" rpy="0 0 0"/>
    </collision>
    <xacro:cylinder_inertia mass="${laser_mass}" radius="${laser_radius}" height="${laser_height}"/>
  </link>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${base_length/4} 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Gazebo 插件 ==================== -->

  <!-- 差速驱动插件：订阅 /cmd_vel，发布 /odom 和 TF -->
  <gazebo reference="base_link">
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive_controller">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>30</update_rate>
      <left_joint>base_to_left_wheel</left_joint>
      <right_joint>base_to_right_wheel</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${wheel_radius * 2}</wheel_diameter>
      <max_wheel_torque>200</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <command_topic>cmd_vel</command_topic>
      <odom_topic>odom</odom_topic>
    </plugin>
  </gazebo>

  <!-- 激光雷达插件：发布 /scan 话题，360度扫描，范围0.1~5m -->
  <gazebo reference="laser_link">
    <plugin filename="libgazebo_ros_ray_sensor.so" name="laser_scanner">
      <ros>
        <namespace>/</namespace>
      </ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <topic_name>scan</topic_name>
      <frame_name>laser_link</frame_name>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </plugin>
  </gazebo>

</robot>
